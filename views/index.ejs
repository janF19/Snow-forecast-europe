<!-- index.ejs -->
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>European Powder Forecast | Ski Resort Snowfall Information</title>
    <link rel="stylesheet" href="/styles/indexStyle.css">
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;600;700&display=swap" rel="stylesheet">
</head>
<body>
    <%- include('partials/navbar') %>
    
    <main class="container">
        <header class="hero-section">
            <h1>European Powder Forecast</h1>
            <div class="hero-content">
                <div class="hero-text">
                    <p>
                        Welcome to your ultimate European powder hunting companion! We track snowfall forecasts and conditions across the Alps and beyond, helping you find the perfect powder days for your next ski adventure.
                    </p>
                    <p>
                        Our platform monitors snow conditions across major ski destinations in Austria, Switzerland, France, Italy, and other European locations. Whether you're planning a trip weeks ahead or looking for last-minute powder stashes, we've got you covered with:
                    </p>
                    <ul>
                        <li>7 and 14-day snowfall forecasts</li>
                        <li>Past 14-day snowfall</li>
                        <li>Historical snowfall analysis based on 30-year seasonal trends</li>
                    </ul>
                </div>
                <div class="hero-image">
                    <img src="/powder_home_img.jpg" alt="Skier in powder snow" class="feature-image">
                </div>
            </div>
        </header>

        <% if (typeof topPowder !== 'undefined' && topPowder && topPowder.length) { %>
        <section class="pqi-home-section">
            <div class="section-one-header">
                <h2>Experimental Powder Conditions Index</h2>
                <div class="button-group"><a href="/powder-quality" class="btn">See experimental conditions</a></div>
            </div>
            <div class="pqi-home-grid">
                <% topPowder.forEach(function(resort) { %>
                    <a href="/powder-quality" class="pqi-card pqi-<%= resort.band %>-border">
                        <span class="pqi-badge pqi-<%= resort.band %>"><%= resort.peakPQI %></span>
                        <span class="pqi-card-name"><%= resort.resort %></span>
                        <span class="pqi-card-meta"><%= resort.freshSnow %> cm &middot; <%= resort.peakDayLabel %></span>
                    </a>
                <% }); %>
            </div>
        </section>
        <% } %>

        <section class="forecast-section">
            <div class="section-one-header">
                <h2>Top 10 Resorts for Upcoming Powder</h2>
                <div class="button-group">
                    <a href="/allResortsCombined" class="btn">View All 7-Day Forecasts</a>
                    <a href="/14dayForecastCombined" class="btn">View All 14-Day Forecasts</a>
                </div>
            </div>
            
            <div class="table-container">
                <table class="forecast-table">
                    <thead>
                        <tr>
                            <th>Resort</th>
                            <th>Elevation (m)</th>
                            <th>3-Day Forecast</th>
                            <th>7-Day Forecast</th>
                            <th>14-Day Forecast</th>
                        </tr>
                    </thead>
                    <tbody>
                        <% sortedByUpcoming7Days.forEach(function(resort) { %>
                            <tr>
                                <td>
                                    <% if (resort.country === 'Switzerland') { %>
                                        <img src="https://flagcdn.com/w20/ch.png" alt="Switzerland" style="width:20px; height:20px; vertical-align: middle; margin-right: 8px;">
                                    <% } else if (resort.country === 'Austria') { %>
                                        <img src="https://flagcdn.com/w20/at.png" alt="Austria" style="width:20px; height:20px; vertical-align: middle; margin-right: 8px;">
                                    <% } else if (resort.country === 'France') { %>
                                        <img src="https://flagcdn.com/w20/fr.png" alt="France" style="width:20px; height:20px; vertical-align: middle; margin-right: 8px;">
                                    <% } else if (resort.country === 'Italy') { %>
                                        <img src="https://flagcdn.com/w20/it.png" alt="Italy" style="width:20px; height:20px; vertical-align: middle; margin-right: 8px;">
                                    <% } else if (resort.country === 'Slovakia') { %>
                                        <img src="https://flagcdn.com/w20/sk.png" alt="Slovakia" style="width:20px; height:20px; vertical-align: middle; margin-right: 8px;">
                                    <% } else if (resort.country === 'Slovenia') { %>
                                        <img src="https://flagcdn.com/w20/si.png" alt="Slovenia" style="width:20px; height:20px; vertical-align: middle; margin-right: 8px;">
                                    <% } else if (resort.country === 'Germany') { %>
                                        <img src="https://flagcdn.com/w20/de.png" alt="Germany" style="width:20px; height:20px; vertical-align: middle; margin-right: 8px;">
                                    <% } %>
                                    <a href="<%- encodeURI(resort.url) %>" target="_blank" class="resort-link" rel="noopener noreferrer">
                                        <%= resort.resort %>
                                    </a>
                                </td>
                                <td><%= resort.elevation %></td>
                                <td><%= resort.threeDaySnowSum.toFixed(1) %> cm</td>
                                <td class="highlight"><%= resort.sevenDaySnowSum.toFixed(1) %> cm</td>
                                <td><%= resort.twoWeeksSnowSum.toFixed(1) %> cm</td>
                            </tr>
                        <% }); %>
                    </tbody>
                </table>
            </div>
        </section>

        <section class="history-section">
            <div class="section-one-header">
                <h2>Recent Snowfall Leaders</h2>
                <div class="button-group">
                    <a href="/past14daysnow" class="btn">View All Historical Data</a>
                </div>
            </div>
            
            <div class="table-container">
                <table class="history-table">
                    <thead>
                        <tr>
                            <th>Resort</th>
                            <th>Elevation (m)</th>
                            <th>Last 14 Days</th>
                        </tr>
                    </thead>
                    <tbody>
                        <% sortedByLast14Days.forEach(function(resort) { %>
                            <tr>
                                <td>
                                    <% if (resort.country === 'Switzerland') { %>
                                        <img src="https://flagcdn.com/w20/ch.png" alt="Switzerland" style="width:20px; height:20px; vertical-align: middle; margin-right: 8px;">
                                    <% } else if (resort.country === 'Austria') { %>
                                        <img src="https://flagcdn.com/w20/at.png" alt="Austria" style="width:20px; height:20px; vertical-align: middle; margin-right: 8px;">
                                    <% } else if (resort.country === 'France') { %>
                                        <img src="https://flagcdn.com/w20/fr.png" alt="France" style="width:20px; height:20px; vertical-align: middle; margin-right: 8px;">
                                    <% } else if (resort.country === 'Italy') { %>
                                        <img src="https://flagcdn.com/w20/it.png" alt="Italy" style="width:20px; height:20px; vertical-align: middle; margin-right: 8px;">
                                    <% } else if (resort.country === 'Slovakia') { %>
                                        <img src="https://flagcdn.com/w20/sk.png" alt="Slovakia" style="width:20px; height:20px; vertical-align: middle; margin-right: 8px;">
                                    <% } else if (resort.country === 'Slovenia') { %>
                                        <img src="https://flagcdn.com/w20/si.png" alt="Slovenia" style="width:20px; height:20px; vertical-align: middle; margin-right: 8px;">
                                    <% } else if (resort.country === 'Germany') { %>
                                        <img src="https://flagcdn.com/w20/de.png" alt="Germany" style="width:20px; height:20px; vertical-align: middle; margin-right: 8px;">
                                    <% } %>
                                    <a href="<%- encodeURI(resort.url) %>" target="_blank" class="resort-link" rel="noopener noreferrer">
                                        <%= resort.resort %>
                                    </a>
                                </td>
                                <td><%= resort.elevation %></td>
                                <td class="highlight"><%= resort.history14daySum.toFixed(1) %> cm</td>
                            </tr>
                        <% }); %>
                    </tbody>
                </table>
            </div>
        </section>

        
        <section class="freeride-home-section">
            <div class="section-one-header"><h2>Top mapped freeride terrain</h2><a href="/freeride" class="btn">View full leaderboard</a></div>
            <div class="table-container"><table class="freeride-table"><thead><tr><th>Resort</th><th>Score</th><th>Mapped terrain</th></tr></thead><tbody>
                <% (freerideTop5 || []).forEach(function(item) { %><tr><td><%= item.resort %></td><td><%= item.score.toFixed(1) %></td><td><%= Math.round(item.freeride_vertical_m).toLocaleString() %> m · <%= item.freeride_length_km.toFixed(1) %> km · <%= item.freeride_run_count %> routes</td></tr><% }); %>
            </tbody></table></div>
        </section>

        <section class="article-section">
          <h2>Historical powder reliability</h2>
          <p>See where powder has historically been most reliable for any date window,
             season by season, based on modelled snowfall — not a forecast.</p>
          <a href="/allHistory" class="btn">Explore historical reliability</a>
        </section>
    </main>
</body>
</html>
