<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Experimental Powder Conditions Index | European Powder Forecast</title>
    <link rel="stylesheet" href="/styles/indexStyle.css">
</head>
<body>
    <%- include('partials/navbar') %>
    <div class="container">
        <section class="forecast-section">
            <div class="section-header">
                <h3>Experimental Powder Conditions Index</h3>
                <p>Resorts ranked by their best powder day in the next 7 days &mdash; an experimental 0&ndash;100 forecast indicator combining fresh snow, temperature, wind, and rain.</p>
            </div>
            <% if (!resorts || resorts.length === 0) { %>
                <p class="pqi-empty">No fresh powder in the forecast right now. Check back when the next storm is on the way.</p>
            <% } else { %>
            <div class="table-container">
                <table class="pqi-table">
                    <thead><tr><th>Rank</th><th>Resort</th><th>Experimental Conditions</th><th>Best Day</th><th>Fresh Snow</th></tr></thead>
                    <tbody>
                        <% resorts.forEach(function(resort, index) { %>
                            <tr class="pqi-row" onclick="togglePqi(this)">
                                <td><%= index + 1 %></td>
                                <td><% if (resort.url && resort.url !== '#') { %><a href="<%= resort.url %>" target="_blank" rel="noopener noreferrer" onclick="event.stopPropagation()"><%= resort.resort %></a><% } else { %><%= resort.resort %><% } %></td>
                                <td><span class="pqi-badge pqi-<%= resort.band %>"><%= resort.peakPQI %></span></td>
                                <td><%= resort.peakDayLabel %></td>
                                <td><%= resort.freshSnow %> cm</td>
                            </tr>
                            <tr class="pqi-detail" hidden><td colspan="5"><table class="pqi-timeline"><thead><tr><th>Elevation</th><% dayLabels.forEach(function(label) { %><th><%= label %></th><% }); %></tr></thead><tbody>
                                <% ['Top Lift', 'Mid Lift', 'Bottom Lift'].forEach(function(lift) { %><tr><td><%= lift %></td><% if (resort.elevations[lift]) { resort.elevations[lift].forEach(function(cell) { %><td class="pqi-cell pqi-<%= cell.band %>"><%= cell.value %></td><% }); } else { dayLabels.forEach(function() { %><td class="pqi-cell pqi-none">&ndash;</td><% }); } %></tr><% }); %>
                            </tbody></table></td></tr>
                        <% }); %>
                    </tbody>
                </table>
            </div>
            <% } %>
        </section>
    </div>
    <script>function togglePqi(row) { var detail = row.nextElementSibling; if (detail && detail.classList.contains('pqi-detail')) { detail.hidden = !detail.hidden; row.classList.toggle('pqi-row-open'); } }</script>
</body>
</html>
